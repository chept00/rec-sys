   "source": [
    "def divide_num(a, b):\n",
    "    if b == 0:\n",
    "        print(\"Error: Division by zero is not allowed.\")\n",
    "        return None  \n",
    "    else:\n",
    "        return a / b\n",
    "\n",
    "# Example usage:\n",
    "result = divide_num(12, 0)\n",
    "if result is not None:\n",
    "    print(result)\n",
    "else:\n",
    "    print(\"Division failed\")"
   ]
  }
